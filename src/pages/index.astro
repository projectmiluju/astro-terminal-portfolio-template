---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogCard from '../components/BlogCard.astro';
import StrengthCard from '../components/StrengthCard.astro';
import { siteConfig } from '../config/site';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-shell">
      <div class="hero-terminal">
        <div class="hero-bar">
          <span class="dot dot-close"></span>
          <span class="dot dot-minimize"></span>
          <span class="dot dot-maximize"></span>
          <span class="hero-title">{siteConfig.name}@portfolio:~</span>
        </div>
        <div class="hero-body">
          <p><span class="prompt">$</span> whoami</p>
          <p class="hero-highlight">{siteConfig.author.name}</p>
          <p><span class="prompt">$</span> cat profile.txt</p>
          <p>{siteConfig.description}</p>
          <p><span class="prompt">$</span> ls sections/</p>
          <div class="hero-tags">
            <span>[projects]</span>
            <span>[blog]</span>
            <span>[about]</span>
            <span>[rss]</span>
          </div>
        </div>
      </div>

      <div class="hero-actions">
        <a href="/projects" class="term-btn">[open projects]</a>
        <a href="/blog" class="term-btn term-btn-ghost">[open blog]</a>
        <a href="/about" class="term-btn term-btn-ghost">[open about]</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-cmd">$ ./strengths.sh</span>
      </div>
      <div class="strengths-grid">
        {siteConfig.strengths.map((strength) => <StrengthCard {...strength} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-cmd">$ ls projects/</span>
        <a href="/projects" class="section-view-all">[view all]</a>
      </div>
      <div class="projects-grid">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            slug={project.slug}
            period={project.data.period}
            role={project.data.role}
            stack={project.data.stack}
            highlights={project.data.highlights}
            metrics={project.data.metrics}
            cover={project.data.cover}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-cmd">$ head blog/*.mdx</span>
        <a href="/blog" class="section-view-all">[view all]</a>
      </div>
      <div class="blog-grid">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            slug={post.slug}
            date={post.data.date}
            summary={post.data.summary}
            category={post.data.category}
            tags={post.data.tags}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-12) 0 var(--space-10);
  }

  .hero-shell {
    display: grid;
    gap: var(--space-6);
  }

  .hero-terminal {
    border: 1px solid var(--color-border);
    background: var(--color-bg-alt);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .hero-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .hero-title {
    margin-left: var(--space-2);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
  }

  .dot-close { background: #ff5f57; }
  .dot-minimize { background: #febc2e; }
  .dot-maximize { background: #28c840; }

  .hero-body {
    padding: var(--space-6);
    font-family: var(--font-mono);
    color: var(--color-text);
  }

  .hero-body p {
    margin: 0 0 var(--space-3);
  }

  .hero-highlight {
    color: var(--color-text-bright);
    font-size: var(--text-xl);
    font-weight: 700;
  }

  .prompt {
    color: var(--color-accent);
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    color: var(--color-accent);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .term-btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
  }

  .term-btn-ghost {
    border-color: var(--color-border);
    color: var(--color-text-muted);
  }

  .section {
    padding: var(--space-6) 0;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
    font-family: var(--font-mono);
  }

  .section-cmd {
    color: var(--color-text-bright);
  }

  .section-view-all {
    color: var(--color-accent);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .strengths-grid,
  .projects-grid,
  .blog-grid {
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .strengths-grid,
    .projects-grid,
    .blog-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
